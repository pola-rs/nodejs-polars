{
  "name": "nodejs-polars",
  "version": "0.25.1",
  "repository": "https://github.com/pola-rs/nodejs-polars.git",
  "license": "MIT",
  "main": "bin/index.js",
  "files": [
    "bin"
  ],
  "keywords": [
    "csv",
    "transform",
    "parse",
    "json",
    "polars",
    "dataframe",
    "data-processing",
    "rust"
  ],
  "napi": {
    "binaryName": "nodejs-polars",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-musl",
      "aarch64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "aarch64-linux-android"
    ]
  },
  "engines": {
    "node": ">= 20"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "bench": "node -r @swc-node/register benchmark/bench.ts",
    "build": "napi build --platform --release --output-dir polars",
    "build:debug": "napi build --platform --output-dir polars",
    "build:ts": " rm -rf bin; tsc -p tsconfig.build.json",
    "cp:bin": "cp ./polars/*.node bin/",
    "format:rs": "cargo fmt",
    "lint:ts:fix": "biome check --write --unsafe {polars,__tests__} && biome format --write {polars,__tests__}",
    "lint:ts": "biome check {polars,__tests__} && biome format {polars,__tests__}",
    "lint": "yarn lint:ts && yarn format:rs",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "node --enable-source-maps --experimental-test-coverage --test-coverage-include='polars/**/*.ts' --import tsx --import ./__tests__/setup.ts --test ./__tests__/*.test.ts",
    "type": "tsc --noEmit -p tsconfig.test.json",
    "version": "napi version",
    "precommit": "yarn lint && yarn type && yarn test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@napi-rs/cli": "^3.7.2",
    "@types/chance": "^1.1.8",
    "@types/node": "^26.1.1",
    "chance": "^1.1.13",
    "tsx": "^4.23.0",
    "typedoc": "^0.28.20",
    "typedoc-plugin-missing-exports": "^4.1.4",
    "typescript": "6.0.3"
  },
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "benches"
  ],
  "trustedDependencies": [
    "@biomejs/biome"
  ]
}
